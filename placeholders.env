# =============================================================================
# placeholders.env — Fill in every value, then run:
#   bash scripts/replace_placeholders.sh
#
# Placeholder format used throughout all .tf / .tfvars / .yml files:
#   __PLACEHOLDER_NAME__
#
# sed replacement (manual, single file):
#   sed -i 's|__TFE_HOSTNAME__|tfe.example.com|g' path/to/file.tf
#
# sed replacement (all files at once):
#   bash scripts/replace_placeholders.sh
# =============================================================================

# ── Terraform Enterprise / Module Registry ────────────────────────────────────
# e.g. tfe.example.com
TFE_HOSTNAME=""

# e.g. MY_ORG
TFE_ORG=""

# ── GitHub Actions ────────────────────────────────────────────────────────────
# e.g. my-github-org
GH_ORG=""

# Repo name only (not full URL), e.g. reusable-workflows
GH_REUSABLE_REPO=""

# GitHub Actions self-hosted runner group for non-prod environments
RUNNER_GROUP_NONPROD=""

# GitHub Actions self-hosted runner group for prod environment
RUNNER_GROUP_PROD=""

# ── Azure: Non-Prod Subscription ─────────────────────────────────────────────
# e.g. aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee
NONPROD_SUBSCRIPTION_ID=""

# Full ARM path: /subscriptions/<id>/resourceGroups/<rg>/providers/Microsoft.Network/virtualNetworks/<vnet>/subnets/<subnet>
NONPROD_AKS_SUBNET_ID=""

# ── Azure: Prod Subscription ─────────────────────────────────────────────────
PROD_SUBSCRIPTION_ID=""
PROD_AKS_SUBNET_ID=""

# ── Key Vault: Service Principal Object IDs ───────────────────────────────────
# Azure AD object ID for the deployment service principal (CI/CD identity)
SPM_OBJECT_ID=""

# Azure AD object ID for the AKS cluster service principal
AKS_SPM_OBJECT_ID=""

# ── Key Vault: Admin Users ────────────────────────────────────────────────────
# Logical name used as the map key in keyvault_admins_app / keyvault_admins_byok
# e.g. john_doe
KEYVAULT_ADMIN_1_NAME=""
# Azure AD object ID for admin 1
KEYVAULT_ADMIN_1_OBJECT_ID=""

KEYVAULT_ADMIN_2_NAME=""
KEYVAULT_ADMIN_2_OBJECT_ID=""

# ── Platform / Synapse / Storage Admin ────────────────────────────────────────
# Azure AD object ID for the platform admin group
PLATFORM_ADMINS_OBJECT_ID=""

# ── Network / Firewall IP Ranges ──────────────────────────────────────────────
# Org public egress CIDR block, e.g. 203.0.113.0/24
ORG_PUBLIC_IP_CIDR=""

# First IP in the org public range, e.g. 203.0.113.0
ORG_PUBLIC_IP_START=""

# Last IP in the org public range, e.g. 203.0.113.255
ORG_PUBLIC_IP_END=""

# First IP in the org internal (RFC1918) range, e.g. 10.0.0.0
ORG_INTERNAL_IP_START=""

# Last IP in the org internal range, e.g. 10.255.255.254
ORG_INTERNAL_IP_END=""

# First IP in the AKS node pool subnet, e.g. 10.100.0.1
AKS_IP_START=""

# Last IP in the AKS node pool subnet, e.g. 10.100.0.254
AKS_IP_END=""

# ── Synapse Regional Firewall IP Ranges ──────────────────────────────────────
# IP ranges for geographic office / datacenter access to Synapse Analytics.
# Add or remove regions by editing synapse.tf locals.synapse_firewall_rules.
SYNAPSE_INDIA_WEST_IP_START=""
SYNAPSE_INDIA_WEST_IP_END=""

SYNAPSE_US_WEST_IP_START=""
SYNAPSE_US_WEST_IP_END=""

SYNAPSE_US_CENTRAL_IP_START=""
SYNAPSE_US_CENTRAL_IP_END=""

# ── Databricks ────────────────────────────────────────────────────────────────
# Full ARM path: /subscriptions/<id>/resourceGroups/<rg>/providers/Microsoft.Databricks/workspaces/<name>
DATABRICKS_WORKSPACE_RESOURCE_ID=""

# e.g. adb-1234567890.12.azuredatabricks.net
DATABRICKS_WORKSPACE_URL=""

# Admin user email address, e.g. admin@your-org.com
DATABRICKS_ADMIN_EMAIL=""

# Logical key used as the map key for the admin user entry, e.g. admin_user
DATABRICKS_ADMIN_KEY=""
